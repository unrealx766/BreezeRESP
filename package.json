{
  "name": "BreezeResp",
  "private": true,
  "version": "1.1.0",
  "description": "A Redis visualization tool for managing and exploring Redis data",
  "license": "Apache-2.0",
  "author": {
    "name": "unrealx766"
  },
  "homepage": "https://github.com/unrealx766/BreezeRESP",
  "repository": {
    "type": "git",
    "url": "https://github.com/unrealx766/BreezeRESP.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "tauri:build:mac": "tauri build --target x86_64-apple-darwin",
    "tauri:build:mac-arm": "tauri build --target aarch64-apple-darwin",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu --bundles deb,appimage,rpm",
    "tauri:build:linux-arm": "tauri build --target aarch64-unknown-linux-gnu --bundles deb,appimage,rpm",
    "version:sync": "node scripts/sync-version.mjs",
    "version:patch": "node scripts/sync-version.mjs patch",
    "version:minor": "node scripts/sync-version.mjs minor",
    "version:major": "node scripts/sync-version.mjs major"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@vueuse/core": "^14.3.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.7",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.5.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
